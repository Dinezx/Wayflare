{
  "version": 2,
  "installCommand": "cd logistics-ai-prototype/frontend && npm install",
  "buildCommand": "cd logistics-ai-prototype/frontend && node ./node_modules/vite/bin/vite.js build",
  "outputDirectory": "logistics-ai-prototype/frontend/dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
